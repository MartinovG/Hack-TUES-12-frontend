# Backend base URL used by the frontend at runtime.
#
# - In development, leaving this unset is fine because vite.config.js proxies /auth,/vms,/rentals
#   to localhost:3000 (or VITE_API_PROXY_TARGET).
# - In production, set this to your public backend URL (same scheme + host + port).
#
# Examples:
# VITE_API_URL=http://178.104.63.93:3000
# VITE_API_URL=https://api.example.com
VITE_API_URL=

# Optional: used only for Vite dev proxy (npm run dev).
# Example: VITE_API_PROXY_TARGET=http://127.0.0.1:3000
VITE_API_PROXY_TARGET=
