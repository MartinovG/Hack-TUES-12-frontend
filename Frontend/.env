# Runtime backend base URL for the frontend.
# Set this to the machine where your NestJS backend is reachable from the browser.
# Example:
# VITE_API_URL=http://178.104.63.93:3000
VITE_API_URL=http://178.104.63.93:3000

# Used only for vite dev proxy (npm run dev). Leave empty unless you want to proxy to a different backend.
VITE_API_PROXY_TARGET=
