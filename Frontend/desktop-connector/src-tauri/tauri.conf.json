{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hive Desktop Connector",
  "version": "0.1.0",
  "identifier": "com.hacktues.hive.desktopconnector",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hive Desktop Connector",
        "label": "main",
        "width": 1320,
        "height": 900,
        "resizable": true,
        "minWidth": 1080,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
